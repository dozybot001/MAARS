# MAARS Configuration
# Copy this to .env and fill in your values

# --- LLM Provider ---
# Model provider: "google", "anthropic", or "openai"
MAARS_AGNO_MODEL_PROVIDER=google
# MAARS_AGNO_MODEL_ID=               # override model (e.g. claude-sonnet-4-5)

# Google (required when provider is google)
MAARS_GOOGLE_API_KEY=
MAARS_GEMINI_MODEL=gemini-2.5-flash

# Anthropic (required when provider is anthropic)
# MAARS_ANTHROPIC_API_KEY=

# OpenAI (required when provider is openai)
# MAARS_OPENAI_API_KEY=

# --- Kaggle ---
# MAARS_KAGGLE_API_TOKEN=            # or use ~/.kaggle/kaggle.json

# --- Research ---
MAARS_RESEARCH_MAX_ITERATIONS=3      # 1 = no evaluate loop, 3 = up to 2 feedback rounds

# --- Docker Sandbox ---
MAARS_DOCKER_SANDBOX_IMAGE=maars-sandbox:latest
MAARS_DOCKER_SANDBOX_TIMEOUT=600     # seconds
MAARS_DOCKER_SANDBOX_MEMORY=4g
MAARS_DOCKER_SANDBOX_CPU=1.0
MAARS_DOCKER_SANDBOX_NETWORK=true    # allow network in sandbox
