# MAARS Configuration
# Copy this to .env and fill in your values

# Google API Key (required when provider is google)
MAARS_GOOGLE_API_KEY=

# Default model (used when provider is google)
MAARS_GEMINI_MODEL=gemini-2.5-flash

# Model provider: "google", "anthropic", or "openai"
# MAARS_AGNO_MODEL_PROVIDER=google
# MAARS_AGNO_MODEL_ID=               # override for non-google (e.g. claude-sonnet-4-5)
# MAARS_OPENAI_API_KEY=
# MAARS_ANTHROPIC_API_KEY=
